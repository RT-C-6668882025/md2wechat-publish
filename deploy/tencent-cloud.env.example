# Content conversion API. This is not a text-generation provider.
MD2WECHAT_API_KEY=
MD2WECHAT_BASE_URL=https://www.md2wechat.cn

# WeChat Official Account publishing credentials.
WECHAT_APPID=
WECHAT_SECRET=

# Optional fixed-egress proxy and runtime controls.
WECHAT_PROXY_URL=
HTTP_TIMEOUT=60
DEFAULT_THEME=default
DEFAULT_BACKGROUND_TYPE=none
